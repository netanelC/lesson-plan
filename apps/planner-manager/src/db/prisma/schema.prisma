// apps/planner-manager/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output = "generated/client"
}

// This is the magic that creates our single source of truth
generator zod {
  provider                  = "zod-prisma-types"
  // We will eventually route this output directly into our shared types package
  output                    = "../../../../../packages/types/src/generated" 
  createInputTypes          = true // Keeps the generated file clean, we only need the base models for now
  createModelTypes          = true
  addInputTypeValidation    = true
  addIncludeType            = false
  addSelectType             = false
}

datasource db {
  provider = "postgresql"
}

model LessonPlan {
  id        String   @id @default(uuid())

  // The triple-slash comments attach Zod validation and Hebrew error messages directly to the generated schema
  /// @zod.string.min(3, { message: "הנושא חייב להכיל לפחות 3 תווים" }).max(100, { message: "הנושא ארוך מדי" })
  topic     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}