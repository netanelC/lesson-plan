generator client {
  provider = "prisma-client-js"
  output = "generated/client"
}

generator zod {
  provider                  = "zod-prisma-types"
  output                    = "../../../../../packages/types/src/generated" 
  createInputTypes          = true
  createModelTypes          = true
  addInputTypeValidation    = true
}

datasource db {
  provider = "postgresql"
}

enum Frame {
  PLENARY
  SMALL_GROUP
}

enum AgeGroup {
  THREE_TO_FOUR
  FOUR_TO_FIVE
}

model LessonPlan {
  id             String   @id @default(uuid())

  /// @zod.string.min(3, { message: "הנושא חייב להכיל לפחות 3 תווים" }).max(100, { message: "הנושא ארוך מדי" })
  topic          String

  /// @zod.string.min(2, { message: "נא להזין יחידת לימוד" })
  unit           String

  frame          Frame
  ageGroup       AgeGroup

  /// @zod.string.min(5, { message: "מטרת העל חייבת להכיל לפחות 5 תווים" })
  superGoal      String
  operativeGoals String[] // prisma doesn't support arrays of objects, so we'll handle this in our types package and validation logic
  lessonFlow     Json
  teachingAids   String[]
  references     String[]

  isPublished    Boolean  @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
