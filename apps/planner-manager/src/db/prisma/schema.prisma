generator client {
  provider = "prisma-client-js"
  output = "generated/client"
}

generator zod {
  provider                  = "zod-prisma-types"
  output                    = "../../../../../packages/types/src/generated" 
  createInputTypes          = true
  createModelTypes          = true
  addInputTypeValidation    = true
}

datasource db {
  provider = "postgresql"
}

enum Frame {
  PLENARY
  SMALL_GROUP
}

enum AgeGroup {
  THREE_TO_FOUR
  FOUR_TO_FIVE
}

enum Role {
  KINDERGARTEN
  ADMIN
  OWNER
}

model User {
  id        String       @id @default(cuid())
  email     String       @unique
  fullName  String
  role      Role         @default(KINDERGARTEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  isActive      Boolean   @default(true)  // For banning users without deleting data

  // Auth: Supports both Email/Password AND Google Login
  passwordHash  String?   // Nullable: Empty if using Google-only
  googleId      String?   @unique // Nullable: Empty if using Password-only
  avatarUrl     String?


  // Relation: A user can author many lesson plans
  lessonPlans LessonPlan[]
}

model LessonPlan {
  id             String   @id @default(uuid())

  /// @zod.string.min(3, { message: "הנושא חייב להכיל לפחות 3 תווים" }).max(100, { message: "הנושא ארוך מדי" })
  topic          String

  /// @zod.string.min(2, { message: "נא להזין יחידת לימוד" })
  unit           String

  frame          Frame
  ageGroup       AgeGroup

  /// @zod.string.min(5, { message: "מטרת העל חייבת להכיל לפחות 5 תווים" })
  superGoal      String
  operativeGoals String[] // prisma doesn't support arrays of objects, so we'll handle this in our types package and validation logic
  priorKnowledge  String?
  lessonFlow     Json
  teachingAids   String[]
  references     String[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  authorId       String
  author         User     @relation(fields: [authorId], references: [id])

  attachments Attachment[]

}

model Attachment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  
  filename  String    // Original filename
  url       String    // MinIO URL
  fileType  String    // MIME type
  sizeBytes Int
  
  // Foreign Key
  lessonPlan   LessonPlan @relation(fields: [lessonPlanId], references: [id], onDelete: Cascade)
  lessonPlanId String
}
