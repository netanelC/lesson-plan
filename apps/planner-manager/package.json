{
  "name": "planner-manager",
  "version": "1.0.0",
  "description": "",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.build.json && pnpm run prisma:copy && tsc-alias -p tsconfig.build.json && pnpm run assets:copy",
    "start": "pnpm run build && cd dist && node ./server.js",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "pretest": "pnpm run test:db:push",
    "test": "vitest run",
    "test:db:push": "pnpm prisma db push --schema ./src/db/prisma/schema.prisma",
    "migration:validate": "pnpm prisma validate --schema ./src/db/prisma/schema.prisma",
    "migration:format": "pnpm prisma format --check --schema ./src/db/prisma/schema.prisma",
    "migration:format-fix": "pnpm prisma format --schema ./src/db/prisma/schema.prisma",
    "migration:dev": "pnpm prisma migrate dev --schema ./src/db/prisma/schema.prisma",
    "migration:generate": "pnpm prisma migrate dev --schema ./src/db/prisma/schema.prisma --name ",
    "migration:generate-types": "pnpm prisma generate --schema ./src/db/prisma/schema.prisma",
    "migration:deploy": "pnpm prisma migrate deploy --schema ./src/db/prisma/schema.prisma",
    "prebuild": "pnpm run clean && pnpm run migration:generate-types",
    "assets:copy": "copyfiles -f ./config/* ./dist/config && copyfiles ./package.json dist && copyfiles -f ./src/db/prisma/migrations/** ./dist/db/prisma/migrations",
    "prisma:copy": "node ./scripts/copyDirectories.mjs ./src/db/prisma/generated ./dist/db/prisma/generated",
    "clean": "rimraf dist"
  },
  "keywords": [],
  "packageManager": "pnpm@10.0.0",
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@fastify/autoload": "^6.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@prisma/client-runtime-utils": "^7.3.0",
    "@repo/types": "workspace:^",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "config": "^4.2.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "google-auth-library": "^10.5.0",
    "http-status": "^2.1.0",
    "pg": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/config": "^3.3.5",
    "@types/node": "catalog:",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "copyfiles": "^2.4.1",
    "eslint": "catalog:",
    "prisma": "^7.3.0",
    "prisma-json-types-generator": "^4.1.1",
    "rimraf": "catalog:",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod-prisma-types": "^3.3.11",
    "zx": "^8.8.5"
  }
}
