{
  "name": "planner-manager",
  "version": "1.0.0",
  "description": "",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.build.json && npm run prisma:copy && tsc-alias -p tsconfig.build.json && npm run assets:copy",
    "start": "npm run build && cd dist && node ./server.js",
    "migration:validate": "npx prisma validate --schema ./src/db/prisma/schema.prisma  ",
    "migration:format": "npx prisma format --check --schema ./src/db/prisma/schema.prisma  ",
    "migration:format-fix": "npx prisma format --schema ./src/db/prisma/schema.prisma  ",
    "migration:dev": "npx prisma migrate dev --schema ./src/db/prisma/schema.prisma",
    "migration:generate": "npx prisma migrate dev --schema ./src/db/prisma/schema.prisma --name ",
    "migration:generate-types": "npx prisma generate --schema ./src/db/prisma/schema.prisma",
    "migration:deploy": "npx prisma migrate deploy --schema ./src/db/prisma/schema.prisma",
    "prebuild": "npm run clean && npm run migration:generate-types",
    "assets:copy": "copyfiles -f ./config/* ./dist/config && copyfiles ./package.json dist && copyfiles -f ./src/db/prisma/migrations/** ./dist/db/prisma/migrations",
    "prisma:copy": "node ./scripts/copyDirectories.mjs ./src/db/prisma/generated ./dist/db/prisma/generated",
    "clean": "rimraf dist"
  },
  "keywords": [],
  "packageManager": "pnpm@10.0.0",
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.981.0",
    "@fastify/autoload": "^6.3.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@prisma/client-runtime-utils": "^7.3.0",
    "@repo/types": "workspace:^",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "config": "^4.2.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "google-auth-library": "^10.5.0",
    "pg": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/config": "^3.3.5",
    "@types/node": "^25.2.0",
    "@types/pg": "^8.16.0",
    "copyfiles": "^2.4.1",
    "prisma": "^7.3.0",
    "rimraf": "^6.1.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zx": "^8.8.5"
  }
}
