{
  "name": "@repo/eslint-config",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "check-types": "tsc --noEmit",
    "pretest": "pnpm run build",
    "test": "vitest run",
    "prepack": "pnpm run build",
    "prebuild": "pnpm run clean",
    "clean": "rimraf dist",
    "build": "tsc --project tsconfig.build.json",
    "check-dist": "publint && attw --profile esm-only --pack ."
  },
  "files": [
    "dist/**/*"
  ],
  "exports": {
    "./ts-base": {
      "types": "./dist/configs/ts-base.d.mts",
      "import": "./dist/configs/ts-base.mjs"
    },
    "./react": {
      "types": "./dist/configs/react.d.mts",
      "import": "./dist/configs/react.mjs"
    },
    "./vitest": {
      "types": "./dist/configs/vitest.d.mts",
      "import": "./dist/configs/vitest.mjs"
    },
    "./helpers": {
      "types": "./dist/helpers.d.mts",
      "import": "./dist/helpers.mjs"
    }
  },
  "peerDependencies": {
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0 || ^7.0.0",
    "@vitest/eslint-plugin": "^1.6.7",
    "globals": "^15.14.0 || ^17.0.0"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-react": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "@vitest/eslint-plugin": {
      "optional": true
    },
    "globals": {
      "optional": true
    }
  },
  "dependencies": {
    "@eslint/js": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.0.0",
    "eslint-plugin-import-x": "^4.16.1",
    "@typescript-eslint/parser": "^8.23.0",
    "typescript-eslint": "^8.23.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react": "7.37.5",
    "@vitest/eslint-plugin": "1.6.7",
    "@repo/vitest-config": "workspace:^",
    "vitest": "catalog:",
    "rimraf": "catalog:"
  }
}
